# === framework-lab — Variáveis de ambiente (template) ===
# Copia este arquivo para .env e preenche com suas credenciais.
# NUNCA commite o arquivo .env.

# OpenRouter API Key
# Obter em: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-COLE_SUA_CHAVE_AQUI

# Base URL OpenRouter (OpenAI-compatible)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model IDs usados no lab
MODEL_GLM=z-ai/glm-5.2
MODEL_HAIKU=anthropic/claude-haiku-4.5
